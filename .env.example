# Copia este archivo como .env y completa los valores

# API Key de Anthropic (obligatorio para normalización via IA)
ANTHROPIC_API_KEY=sk-ant-...

# Directorio con los archivos de datos (por defecto: carpeta padre del proyecto)
# DATA_DIR=/ruta/a/los/datos

# Puerto del servidor (por defecto: 8000)
# PORT=8000
